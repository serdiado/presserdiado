# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database (MySQL/MariaDB)
DATABASE_URL=mysql://root:@localhost:3306/matbaapro

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=matbaapro
S3_SECRET_KEY=matbaapro_dev
S3_BUCKET=matbaapro
S3_REGION=us-east-1

# CORS — birden fazla origin icin virgulle ayirin
CORS_ORIGIN=http://localhost:5173

# Web app URL (Puppeteer export icin: /print-view buraya gider)
WEB_BASE_URL=http://localhost:5173
