# =============================================================================
# MatbaaPro API — Production (.env.production.example)
#
# Production'a deploy ederken bu dosyayi `.env.production` olarak kopyalayin
# ve gercek degerlerle doldurun. .env.production gitignore'da, asla commit'lemeyin.
#
# Domain plani:
#   Web        : https://serdiado.de
#   API        : https://api.serdiado.de
#   Uploads    : https://api.serdiado.de/uploads/...
#   Print-view : https://serdiado.de/print-view (Puppeteer buraya gider)
# =============================================================================

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# Database — MySQL/MariaDB
# Format: mysql://USER:PASS@HOST:3306/DATABASE
# SSL gerekiyorsa: mysql://USER:PASS@HOST:3306/DATABASE?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://USER:PASS@db-host:3306/matbaapro

# Redis — managed Redis (ElastiCache / Upstash / vb.)
REDIS_URL=rediss://USER:PASS@redis-host:6380

# JWT — `openssl rand -hex 64` ile uretilmis uzun rastgele degerler kullanin
JWT_SECRET=GENERATE_WITH_openssl_rand_hex_64
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_openssl_rand_hex_64

# S3 — production icin gercek S3 / R2 / MinIO endpoint'i
# (su an upload modulu lokal diske yaziyor; ileride S3'e tasinabilir)
S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
S3_ACCESS_KEY=PROD_ACCESS_KEY
S3_SECRET_KEY=PROD_SECRET_KEY
S3_BUCKET=matbaapro-prod
S3_REGION=eu-central-1

# CORS — sadece resmi domain(ler)
CORS_ORIGIN=https://serdiado.de

# Web app URL — Puppeteer export icin (HTTPS olmali, public erisilebilir)
WEB_BASE_URL=https://serdiado.de
